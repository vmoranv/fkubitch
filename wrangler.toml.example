name = "fuckubitch"
main = "src/worker/index.ts"
compatibility_date = "2024-12-01"

[[d1_databases]]
binding = "DB"
database_name = "your-db-name"
database_id = "your-database-id"

[vars]
ENVIRONMENT = "production"
CORS_ORIGIN = "https://your-project.pages.dev"
JWT_SECRET = "your-jwt-secret-min-32-chars"
GITHUB_CLIENT_ID = "your-github-client-id"
GITHUB_CLIENT_SECRET = "your-github-client-secret"
GOOGLE_CLIENT_ID = "your-google-client-id"
GOOGLE_CLIENT_SECRET = "your-google-client-secret"
# Turnstile is opt-in. To enable:
#   1. Get site key + secret key from Cloudflare → Turnstile
#   2. Set TURNSTILE_SITE_KEY here (it ships to the browser, public)
#   3. wrangler secret put TURNSTILE_SECRET_KEY  (never commit the secret)
#   4. Flip TURNSTILE_ENABLED to "true"
# Frontend reads TURNSTILE_SITE_KEY via /api/auth/config — no separate
# build-time env var needed.
TURNSTILE_ENABLED = "false"
TURNSTILE_SITE_KEY = "your-turnstile-site-key"
ADMIN_API_KEY = "your-admin-key"
